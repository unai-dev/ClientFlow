@page "/auth/login"
@inject NavigationManager NavManager
@inject IAuthService AuthService
@inject ILocalStorageService LocalStorage
@inject IJSCustomEvents JS

<!-- Verificar autenticación al cargar -->
@if (isLoading)
{
    <div style="display: flex; align-items: center; justify-content: center; min-height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div style="background: white; padding: 40px; border-radius: 12px; text-align: center;">
            <p style="margin: 0; color: #667eea; font-weight: 600;">Cargando...</p>
        </div>
    </div>
}
else
{
    <!-- Componente del formulario de login -->
    <AuthForm Credentials="credentials"
              CurrentPost="isPosting"
              FormTitle="Iniciar Sesión"
              OnSubmit="HandleLogin" />

    <!-- Link al register -->
    <div style="text-align: center; margin-top: 20px; margin-bottom: 20px;">
        <p style="color: #666; font-size: 14px; margin: 0;">
            ¿No tienes cuenta?
            <a href="/auth/register" style="color: #667eea; text-decoration: none; font-weight: 600; cursor: pointer;">Registrate aquí</a>
        </p>
    </div>
}

@code {
    private CredentialsDTO credentials = new();
    private bool isPosting = false;
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {

        try
        {
            var token = await LocalStorage.GetItemLocalStorageAsync("token");

            if (!string.IsNullOrEmpty(token))
            {
                NavManager.NavigateTo("/");
                return;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verificando autenticación: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }


    private async Task HandleLogin()
    {
        isPosting = true;

        try
        {
            var response = await AuthService.Login(credentials);

            if (!string.IsNullOrEmpty(response!.Token))
            {
                await JS.CustomAlert("¡Bienvenido de nuevo!");
                await LocalStorage.SetItemLocalStorageAsync("token", response.Token);
                NavManager.NavigateTo("/");
            }
            else
            {
                errorMessage = response.ToString()!;
            }

            Console.WriteLine("Login procesando...");
        }
        catch (Exception ex)
        {
            await JS.CustomAlert("Credenciales incorrectas. Por favor, intenta de nuevo.");

            Console.WriteLine($"Error en login: {ex.Message}");
        }
        finally
        {
            isPosting = false;
        }
    }
}
