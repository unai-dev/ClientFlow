@using ClientFlow.UI.Features.ClientNotes.Components
<div class="client-list-container">
    <!-- Encabezado con título y botón crear -->
    <div class="client-list-header">
        <h2 class="client-list-title">Mis Clientes</h2>
        <BPButton class="btn btn-primary" OnClick="OnCreateClick">
            <span class="btn-icon">+</span>
            <span class="btn-text">Nuevo Cliente</span>
        </BPButton>
    </div>

    <!-- Formulario de creación (modal/inline) -->
    @if (ShowCreateForm)
    {
        <div class="client-form-wrapper">
            <div class="client-form-header">

                <h3>Agregar Nuevo Cliente</h3>
                <BPButton class="btn-close" OnClick="OnCreateButtonClick">✕</BPButton>
            </div>
            <ClientForm CreateClient="NewClient"
                        CurrentPost="IsCreating"
                        OnValidSubmit="OnFormSubmit" />
        </div>
    }

    <!-- Lista de clientes -->
    <div class="client-list">
        @if (IsLoading)
        {
            <div class="loading-state">
                <p>Cargando clientes...</p>
            </div>
        }
        else if (Clients == null || Clients.Count == 0)
        {
            <div class="empty-state">
                <p>No hay clientes aún</p>
                <small>Crea tu primer cliente haciendo clic en el botón "Nuevo Cliente"</small>
            </div>
        }
        else
        {
            @foreach (var client in Clients)
            {
                <ClientCard Client="client"
                            OnView="@(() => OnClientView.InvokeAsync(client))"
                            OnDelete="@((id) => OnClientDelete.InvokeAsync(id))"
                            OnAddNote="@((id) => OnAddNoteClick.InvokeAsync(id))" />
            }
        }
    </div>

    <!-- Modal de confirmación de eliminación -->
    @if (ShowDeleteModal)
    {
        <ConfirmDelete ClientId="ClientIdToDelete"
                       OnDelete="OnConfirmDelete"
                       OnCancel="OnClientCancel" />
    }

    @if (ShowClientDetails)
    {
        <ClientDetails Client="SelectedClient" OnClose="OnCloseClientView" />
    }

    @if (ShowNoteForm)
    {
        <NoteForm CurrentPost="IsCreating" ClientNote="NewNote" OnAddNote="@(() => OnAddNote.InvokeAsync(NewNote))" OnClose="HandleCloseNoteForm" />
    }
</div>

@code {
    [Parameter] public List<ClientDTO> Clients { get; set; } = new();

    [Parameter] public ClientDTO? SelectedClient { get; set; } = new();

    [Parameter] public CreateClientDTO NewClient { get; set; } = new();

    [Parameter] public CreateClientNoteDTO NewNote { get; set; } = new();

    [Parameter, EditorRequired] public int ClientIdToDelete { get; set; }

    [Parameter] public bool ShowCreateForm { get; set; } = false;

    [Parameter] public bool ShowClientDetails { get; set; } = false;

    [Parameter] public bool ShowNoteForm { get; set; } = false;

    [Parameter] public bool ShowDeleteModal { get; set; } = false;

    [Parameter] public bool IsLoading { get; set; } = false;

    [Parameter] public bool IsCreating { get; set; } = false;

    [Parameter] public EventCallback OnCreateButtonClick { get; set; }

    [Parameter] public EventCallback OnFormSubmitted { get; set; }

    [Parameter, EditorRequired] public EventCallback<ClientDTO> OnClientView { get; set; }

    [Parameter, EditorRequired] public EventCallback<int> OnAddNoteClick { get; set; }

    [Parameter, EditorRequired] public EventCallback<CreateClientNoteDTO> OnAddNote { get; set; }

    [Parameter, EditorRequired] public EventCallback OnCloseClientView { get; set; }

    [Parameter, EditorRequired] public EventCallback OnCloseNoteForm { get; set; }

    [Parameter, EditorRequired] public EventCallback<int> OnClientDelete { get; set; }

    [Parameter, EditorRequired] public EventCallback<int> OnConfirmDelete { get; set; }

    [Parameter, EditorRequired] public EventCallback OnClientCancel { get; set; }

    private async Task OnCreateClick()
    {
        await OnCreateButtonClick.InvokeAsync();
    }

    private async Task OnFormSubmit()
    {
        await OnFormSubmitted.InvokeAsync();
    }

    private async Task HandleCloseNoteForm()
    {
        await OnCloseNoteForm.InvokeAsync();
    }
}
