@using ClientFlow.Shared.DTOs.Client

<div class="client-list-container">
    <!-- Encabezado con título y botón crear -->
    <div class="client-list-header">
        <h2 class="client-list-title">Mis Clientes</h2>
        <button class="btn-create-client" @onclick="OnCreateClick">
            <span class="btn-icon">+</span>
            <span class="btn-text">Nuevo Cliente</span>
        </button>
    </div>

    <!-- Formulario de creación (modal/inline) -->
    @if (ShowCreateForm)
    {
        <div class="client-form-wrapper">
            <div class="client-form-header">
                <h3>Agregar Nuevo Cliente</h3>
                <button class="btn-close" @onclick="OnCloseFormClick">✕</button>
            </div>
            <ClientForm CreateClient="NewClient"
                        CurrentPost="IsCreating"
                        OnValidSubmit="OnFormSubmit" />
        </div>
    }

    <!-- Lista de clientes -->
    <div class="client-list">
        @if (IsLoading)
        {
            <div class="loading-state">
                <p>Cargando clientes...</p>
            </div>
        }
        else if (Clients == null || Clients.Count == 0)
        {
            <div class="empty-state">
                <p>No hay clientes aún</p>
                <small>Crea tu primer cliente haciendo clic en el botón "Nuevo Cliente"</small>
            </div>
        }
        else
        {
            @foreach (var client in Clients)
            {
                <ClientCard Client="client"
                            OnView="@(() => OnClientView.InvokeAsync(client))"
                            OnDelete="@(() => OnClientDelete.InvokeAsync(client.Id))" />
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public List<ClientDTO> Clients { get; set; } = new();

    [Parameter]
    public CreateClientDTO NewClient { get; set; } = new();

    [Parameter]
    public bool ShowCreateForm { get; set; } = false;

    [Parameter]
    public bool IsLoading { get; set; } = false;

    [Parameter]
    public bool IsCreating { get; set; } = false;

    [Parameter]
    public EventCallback OnCreateButtonClick { get; set; }

    [Parameter]
    public EventCallback OnCloseForm { get; set; }

    [Parameter]
    public EventCallback OnFormSubmitted { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<ClientDTO> OnClientView { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<int> OnClientDelete { get; set; }

    private async Task OnCreateClick()
    {
        await OnCreateButtonClick.InvokeAsync();
    }

    private async Task OnCloseFormClick()
    {
        await OnCloseForm.InvokeAsync();
    }

    private async Task OnFormSubmit()
    {
        await OnFormSubmitted.InvokeAsync();
    }
}
