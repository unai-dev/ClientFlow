
<div class="rounded-4 shadow-lg p-4 align-content-center w-100 h-100 mt-5 ">
    <EditForm EditContext="@editContext" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <BPInputText Label="Nombre*" Placeholder="Unai Villar Lopez" @bind-Value="CreateClient.FullName" />
        <BPInputText Label="Email" Placeholder="unaivl123@gmail.com" @bind-Value="CreateClient.Email" />

        <BPInputNumber Label="Telefono" Placeholder="123456789" @bind-Value="CreateClient.Phone" />

        <BPInputText Label="Empresa" Placeholder="Vodafone" @bind-Value="CreateClient.Company" />
        <BPInputText Label="Puesto" Placeholder="Desarrollador Backend" @bind-Value="CreateClient.Position" />

        <BPButton class="btn btn-primary w-100 mt-3" Disabled="@CurrentPost">
            @if (CurrentPost)
            {
                <span>Agregando...</span>
            }
            else
            {
                <span>Agregar Cliente</span>
            }
        </BPButton>
    </EditForm>
</div>




@code {

    [Parameter, EditorRequired] public bool CurrentPost { get; set; } = false;
    [Parameter, EditorRequired] public CreateClientDTO CreateClient { get; set; }
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }

    private EditContext? editContext;

    protected override void OnInitialized()
    {
        editContext = new(CreateClient);
    }

    private async Task HandleValidSubmit()
    {
        if (editContext is not null && editContext.Validate())
        {

            await OnValidSubmit.InvokeAsync();
        }
    }
}
