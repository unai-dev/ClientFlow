@page "/dashboard"
@using ClientFlow.UI.Features.Client.Components
@using ClientFlow.UI.Features.Client.Interfaces
@using ClientFlow.Shared.DTOs.Client
@inject IClientService ClientService
@inject NavigationManager NavManager
@inject ILocalStorageService LocalStorage

<div class="dashboard-container">
    @if (isAuthenticated)
    {
        <!-- Contenido del dashboard -->
        <div class="dashboard-header">
            <h1 class="dashboard-title">Dashboard</h1>
            <p class="dashboard-subtitle">Gestiona tu cartera de clientes</p>
        </div>

        <!-- Componente de lista de clientes -->
        <ClientList Clients="clients"
                    NewClient="newClient"
                    ShowCreateForm="showCreateForm"
                    IsLoading="isLoading"
                    IsCreating="isCreating"
                    ShowDeleteModal="showDeleteModal"
                    ClientIdToDelete="clientIdToDelete"
                    ShowClientDetails="showClientDetailsModal"
                    SelectedClient="selectedClient"
                    OnCreateButtonClick="HandleOpenCreateForm"
                    OnCloseForm="HandleCloseCreateForm"
                    OnFormSubmitted="HandleCreateClient"
                    OnClientView="HandleViewClient"
                    OnClientDelete="HandleOpenDeleteModal"
                    OnConfirmDelete="HandleConfirmDelete"
                    OnClientCancel="HandleCancelDelete"
                    OnCloseClientView="HandleCloseClientDetails" />
    }
    else
    {
        <div class="no-auth-container">
            <div class="no-auth-card">
                <h2>Acceso Denegado</h2>
                <p>Por favor, inicia sesión para acceder al dashboard</p>
                <a href="/auth/login" class="btn-login">Ir a Login</a>
            </div>
        </div>
    }
</div>

@code {
    private List<ClientDTO?> clients = new();
    private CreateClientDTO newClient = new();
    private ClientDTO selectedClient = new();

    private bool isAuthenticated = false;
    private bool showCreateForm = false;
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showDeleteModal = false;
    private bool showClientDetailsModal = false;

    private int clientIdToDelete = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await LocalStorage.GetItemLocalStorageAsync("token");
            isAuthenticated = !string.IsNullOrEmpty(token);

            if (!isAuthenticated)
            {
                NavManager.NavigateTo("/auth/login");
            }
            else
            {
                await LoadClients();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verificando autenticación: {ex.Message}");
            NavManager.NavigateTo("/auth/login");
        }
    }

    private async Task LoadClients()
    {
        try
        {
            isLoading = true;
            clients = await ClientService.GetClientsAsync() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando clientes: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleOpenCreateForm()
    {
        showCreateForm = true;
        newClient = new CreateClientDTO();
    }

    private void HandleCloseCreateForm()
    {
        showCreateForm = false;
        newClient = new CreateClientDTO();
    }

    private async Task HandleCreateClient()
    {
        isCreating = true;
        try
        {
            var result = await ClientService.CreateClientAsync(newClient);
            if (result != null)
            {
                HandleCloseCreateForm();
                await LoadClients();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creando cliente: {ex.Message}");
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task HandleViewClient(ClientDTO client)
    {
        try
        {
            selectedClient = await ClientService.GetClientAsync(client.Id);
            Console.WriteLine($"Cliente selecionado: {client}");
            showClientDetailsModal = true;

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al obtener usuario con id: {client.Id}. Mensaje: {ex.Message}");
        }
        finally
        {
            showClientDetailsModal = false;
        }

    }

    private void HandleOpenDeleteModal(int clientId)
    {
        clientIdToDelete = clientId;
        showDeleteModal = true;
    }

    private async Task HandleConfirmDelete(int clientId)
    {
        try
        {
            var result = await ClientService.DeleteClientAsync(clientId);
            if (result == true)
            {
                HandleCancelDelete();
                await LoadClients();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error eliminando cliente: {ex.Message}");
        }
    }

    private void HandleCancelDelete()
    {
        showDeleteModal = false;
        clientIdToDelete = 0;
    }

    private void HandleCloseClientDetails()
    {
        selectedClient = new();
        showClientDetailsModal = false;
    }
}
