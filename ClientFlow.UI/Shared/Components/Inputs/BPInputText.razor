<div class="form-group mb-3">
    <label class="form-label text-muted fw-bold text-uppercase small">@Label</label>

    <InputText Value="@Value" ValueChanged="@ValueChanged" ValueExpression="@ValueExpression" class="form-control mb-3" placeholder="@Placeholder" />

    <ValidationMessage For="@ValueExpression" class="validation-error" />
</div>


@code {
    [Parameter, EditorRequired] public string Label { get; set; }
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = null!;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public Expression<Func<string>> ValueExpression { get; set; } = null!;

}
